-- 10. Retrieve the course name, and the name of prerequisite course for those
--     courses that have prerequisites.
SELECT c.course_name AS course, p.course_name AS prerequisite
FROM course c JOIN course p ON c.preq = p.course_id;

-- 11. Retrieve the first and last name of all faculty who have the same rank as
--     Kim Cox. Do not show Kim Cox in the result.
SELECT f.f_first, f.f_last
FROM faculty f JOIN faculty k ON f.f_rank = k.f_rank
WHERE k.f_first = 'Kim'
  AND k.f_last = 'Cox'
  AND NOT (f.f_first = 'Kim' AND f.f_last = 'Cox');


-- 12. Retrieve all student last names of those that are advised by Sarah 
--     Miller's in the result
SELECT s2.s_last
FROM student s1
JOIN student s2 ON s1.f_id = s2.f_id
WHERE s1.s_first = 'Sarah'
  AND s1.s_last = 'Miller'
  AND NOT (s2.s_first = 'Sarah' AND s2.s_last = 'Miller');
