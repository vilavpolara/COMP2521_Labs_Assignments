-- Retrieve all the course sections that happen in room 101. Write this WITHOUT the use rof a sub-query

SELECT *
FROM course_section JOIN location USING (loc_id)
WHERE room = 101;

-- Retrieve all the course sections that happen in room 101. Write this using a subqyery
-- Equal operator example

SELECT *
FROM course_section
WHERE loc_id = (SELECT loc_id
                 FROM location
                 WHERE room = 101);

-- In Operator Example

SELECT *
FROM course_section
WHERE loc_id IN (SELECT loc_id
                 FROM location
                 WHERE bldg_code LIKE 'BUS');

-- Example of a join mixed with subqueries

SELECT c_sec_id, f_last, f_first
FROM course_section cs JOIN faculty f USING (f_id)
WHERE cs.loc_id = (SELECT loc_id
                   FROM location
                   WHERE room = 101);

-- Retrieve the students last and first name of all students who are advised by Kim Cox. Write this query in two different ways.

SELECT s_last, s_first
FROM student JOIN faculty USING (f_id)
WHERE f_last = 'Cox' AND f_first = 'Kim';

SELECT s_last, s_first
FROM student
WHERE f_id IN (SELECT f_id
              FROM faculty
              WHERE f_last = 'Cox' AND f_first = 'Kim');

-- Retrieve the c_sec_id of the record which corresponds with the section of the MOST value for the max_enrl column.

SELECT c_sec_id
FROM course_section
WHERE max_enrl = (SELECT MAX(max_enrl)
                  FROM course_section);

SELECT c_sec_id
FROM course_section
WHERE max_enrl = (SELECT MIN(max_enrl)
                  FROM course_section);

-- Retrieve all course sections (display the term id and max_enrl column values) whose maximum enrollment is more 
-- than the average value in the max_enrl column of its term. 
-- (Corelated subquery example)

SELECT c_sec_id, term_id, max_enrl
FROM course_section cs
WHERE max_enrl > (SELECT AVG(max_enrl)
                  FROM course_section
                  WHERE term_id = cs.term_id);

-- Retrieve the student last name of all students who are enrolled in course_id 3
-- (Nested subquery example)

SELECT s_last
FROM student
WHERE s_id IN (SELECT s_id
               FROM enrollment
               WHERE c_sec_id IN (SELECT c_sec_id
                                  FROM course_section
                                  WHERE course_id = 3));

-- Retrieve the student last name of all students who are enrolled in course "Database Management"
-- (Nested subquery example)

SELECT s_last
FROM student
WHERE s_id IN (SELECT s_id
               FROM enrollment
               WHERE c_sec_id IN (SELECT c_sec_id
                                  FROM course_section
                                  WHERE course_id IN (SELECT course_id
                                                     FROM course
                                                     WHERE course_name = 'Database Management')));

-- Retrieve the course section time and duration and loc_id of all course sections of the course "Database Management" during 'OPEN' terms.
-- (Multiple subquery)

SELECT c_sec_time, c_sec_duration, loc_id
FROM course_section
WHERE course_id IN (SELECT course_id
                    FROM course
                    WHERE course_name = 'Database Management')
    AND term_id IN (SELECT term_id
                    FROM term
                    WHERE status = 'OPEN');

-- Retrieve the grade and the term id values for the student Sarak Miller's System Analysis course.
SELECT grade, term_id
FROM enrollment
WHERE s_id IN (SELECT s_id
               FROM student
               WHERE s_last = 'Miller' AND s_first = 'Sarah')
    AND c_sec_id IN (SELECT c_sec_id
                     FROM course_section
                     WHERE course_id IN (SELECT course_id
                                        FROM course
                                        WHERE course_name = 'System Analysis'));